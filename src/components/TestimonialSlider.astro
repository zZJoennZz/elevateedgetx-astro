---
// TestimonialSlider Component - Vanilla JavaScript Version
export interface Testimonial {
    id: number;
    quote: string;
    name: string;
    title: string;
    company: string;
    initials: string;
}

const testimonials: Testimonial[] = [
    {
        id: 1,
        quote: "For almost 10 years now, I have valued Bravis' discernment, vision and focus in business. I've watched Bravis build and scale a manufacturing company firsthand, and his ability to turn strategy into systems that drive growth is real. He doesn't just design high-level plans; he builds the operational frameworks that remove constraints and unlock value inside founder-led, tech-forward manufacturing businesses.",
        name: 'Blake White',
        title: 'President and CFO',
        company: 'Pureous Products, LLC',
        initials: 'B',
    },
    {
        id: 2,
        quote: "Working with ElevateEdge transformed our approach to growth. Their systematic methodology helped us identify blind spots we didn't know existed and created a clear path forward. The operational frameworks they built continue to drive value years later.",
        name: 'Sarah Johnson',
        title: 'CEO',
        company: 'Innovation Technologies',
        initials: 'S',
    },
    {
        id: 3,
        quote: "Bravis brought clarity to our leadership team when we needed it most. His ability to align strategy with execution is unmatched. We've seen measurable improvements in every area he touched.",
        name: 'Michael Chen',
        title: 'Managing Director',
        company: 'Summit Capital Partners',
        initials: 'M',
    },
    {
        id: 4,
        quote: "The operational frameworks ElevateEdge built for us completely transformed how we think about growth. Bravis doesn't just advise—he builds systems that work. Our efficiency has increased by over 40% since implementing their recommendations.",
        name: 'Jennifer Williams',
        title: 'COO',
        company: 'Apex Manufacturing Group',
        initials: 'J',
    },
];
---

<div class="testimonial-slider relative py-16 px-6 md:px-12 rounded-3xl overflow-hidden group">
    <!-- Background gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-deep-slate via-rich-blue to-deep-slate"></div>

    <!-- Animated orbs -->
    <div class="orb w-[400px] h-[400px] bg-vibrant-teal/30 top-0 right-0" style="animation-duration: 15s;"></div>
    <div class="orb w-[300px] h-[300px] bg-amber/20 bottom-0 left-0" style="animation-duration: 12s;"></div>

    <!-- Slider Container -->
    <div class="relative z-10">
        <!-- Testimonials Container - Hide all by default except first via CSS -->
        <div class="testimonials-container relative">
            {
                testimonials.map((testimonial, index) => (
                    <div
                        class="testimonial-slide max-w-4xl mx-auto text-center"
                        data-slide-index={index}
                        style={index === 0 ? 'display: block;' : 'display: none;'}
                    >
                        <i class="fas fa-quote-left text-5xl text-amber/50 mb-6 block" />
                        <p class="text-xl md:text-2xl text-white leading-relaxed mb-8">"{testimonial.quote}"</p>
                        <div class="inline-flex items-center gap-4 bg-white/10 backdrop-blur-sm rounded-full px-6 py-3">
                            <div class="w-12 h-12 bg-amber rounded-full flex items-center justify-center text-deep-slate font-bold text-lg">
                                {testimonial.initials}
                            </div>
                            <div class="text-left">
                                <div class="font-bold text-white">{testimonial.name}</div>
                                <div class="text-white/70 text-sm">
                                    {testimonial.title}, {testimonial.company}
                                </div>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Navigation Dots -->
        <div class="flex justify-center gap-2 mt-8 dots-container">
            {
                testimonials.map((_, index) => (
                    <button
                        class="dot transition-all duration-300 rounded-full w-2 h-2 bg-white/50 hover:bg-white/75"
                        data-dot-index={index}
                        aria-label={`Go to testimonial ${index + 1}`}
                    ></button>
                ))
            }
        </div>

        <!-- Navigation Arrows -->
        <button
            class="prev-btn absolute left-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/20 transition-all opacity-0 group-hover:opacity-100"
            aria-label="Previous testimonial"
        >
            <i class="fas fa-chevron-left"></i>
        </button>

        <button
            class="next-btn absolute right-4 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center text-white hover:bg-white/20 transition-all opacity-0 group-hover:opacity-100"
            aria-label="Next testimonial"
        >
            <i class="fas fa-chevron-right"></i>
        </button>
    </div>
</div>

<script is:inline>
    class TestimonialSlider {
        constructor(container) {
            this.container = container;
            this.slides = container.querySelectorAll('.testimonial-slide');
            this.dots = container.querySelectorAll('.dot');
            this.prevBtn = container.querySelector('.prev-btn');
            this.nextBtn = container.querySelector('.next-btn');
            this.currentIndex = 0;
            this.totalSlides = this.slides.length;
            this.autoPlayInterval = null;

            this.init();
        }

        init() {
            // Ensure only first slide is visible (double-check)
            this.slides.forEach((slide, index) => {
                if (index === this.currentIndex) {
                    slide.style.display = 'block';
                } else {
                    slide.style.display = 'none';
                }
            });

            // Set initial dot state
            this.updateDots();

            // Add event listeners
            if (this.prevBtn) {
                this.prevBtn.addEventListener('click', () => this.prev());
            }

            if (this.nextBtn) {
                this.nextBtn.addEventListener('click', () => this.next());
            }

            // Add dot click handlers
            this.dots.forEach((dot, index) => {
                dot.addEventListener('click', () => this.goToSlide(index));
            });

            // Start auto-play
            this.startAutoPlay();

            // Pause auto-play on hover
            this.container.addEventListener('mouseenter', () => this.stopAutoPlay());
            this.container.addEventListener('mouseleave', () => this.startAutoPlay());
        }

        goToSlide(index) {
            if (index === this.currentIndex) return;

            // Hide current slide
            this.slides[this.currentIndex].style.display = 'none';

            // Show new slide
            this.currentIndex = index;
            this.slides[this.currentIndex].style.display = 'block';

            // Update dots
            this.updateDots();
        }

        next() {
            const nextIndex = (this.currentIndex + 1) % this.totalSlides;
            this.goToSlide(nextIndex);
        }

        prev() {
            const prevIndex = (this.currentIndex - 1 + this.totalSlides) % this.totalSlides;
            this.goToSlide(prevIndex);
        }

        updateDots() {
            this.dots.forEach((dot, index) => {
                if (index === this.currentIndex) {
                    dot.classList.remove('w-2', 'bg-white/50');
                    dot.classList.add('w-8', 'bg-amber');
                } else {
                    dot.classList.remove('w-8', 'bg-amber');
                    dot.classList.add('w-2', 'bg-white/50');
                }
            });
        }

        startAutoPlay() {
            if (this.autoPlayInterval) return;
            this.autoPlayInterval = setInterval(() => this.next(), 8000);
        }

        stopAutoPlay() {
            if (this.autoPlayInterval) {
                clearInterval(this.autoPlayInterval);
                this.autoPlayInterval = null;
            }
        }
    }

    // Initialize slider when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
            const sliderElement = document.querySelector('.testimonial-slider');
            if (sliderElement) {
                new TestimonialSlider(sliderElement);
            }
        });
    } else {
        const sliderElement = document.querySelector('.testimonial-slider');
        if (sliderElement) {
            new TestimonialSlider(sliderElement);
        }
    }
</script>

<style is:global>
    .testimonial-slide {
        transition: opacity 0.5s ease;
    }

    /* Ensure only first slide is visible during initial render */
    .testimonial-slider .testimonial-slide:first-child {
        display: block;
    }

    .testimonial-slider .testimonial-slide:not(:first-child) {
        display: none;
    }
</style>
