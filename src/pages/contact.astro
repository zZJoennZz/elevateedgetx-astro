---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us | ElevateEdge Consulting">
    <Navigation />

    <!-- Hero Section -->
    <section class="relative min-h-[60vh] pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
        <!-- Animated gradient orbs -->
        <div class="orb w-[500px] h-[500px] bg-vibrant-teal/30 top-20 -left-48" style="animation-delay: 0s;"></div>
        <div class="orb w-[400px] h-[400px] bg-amber/20 bottom-20 -right-48" style="animation-delay: 2s;"></div>
        <div class="orb w-[300px] h-[300px] bg-rich-blue/20 top-1/2 left-1/2 -translate-x-1/2" style="animation-delay: 4s;"></div>

        <div class="relative max-w-7xl mx-auto px-6 md:px-10">
            <div class="text-center max-w-4xl mx-auto reveal-on-scroll">
                <div
                    class="inline-flex items-center gap-2 bg-vibrant-teal/10 backdrop-blur-sm px-4 py-2 rounded-full mb-6 border border-vibrant-teal/20"
                >
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-vibrant-teal opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-vibrant-teal"></span>
                    </span>
                    <span class="text-xs font-semibold text-vibrant-teal tracking-wide">GET IN TOUCH</span>
                </div>

                <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.1] tracking-tight mb-6">
                    Let's Talk
                    <span class="shimmer-text">Strategy.</span>
                </h1>

                <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-2xl mx-auto">
                    Whether you're scaling operations, preparing for a transition, or navigating complex growth—we're ready to dig in and help.
                </p>

                <div class="flex flex-wrap gap-4 justify-center">
                    <a
                        href="tel:14322548288"
                        class="flex items-center gap-2 bg-white shadow-lg rounded-full px-6 py-3 hover:shadow-xl transition-all duration-300 group"
                    >
                        <i class="fas fa-phone-alt text-vibrant-teal group-hover:scale-110 transition"></i>
                        <span class="font-semibold text-deep-slate">(432) 254-8288</span>
                    </a>
                    <a
                        href="https://www.linkedin.com/in/bravis-brown-mba/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-2 bg-white shadow-lg rounded-full px-6 py-3 hover:shadow-xl transition-all duration-300 group"
                    >
                        <i class="fab fa-linkedin text-vibrant-teal group-hover:scale-110 transition"></i>
                        <span class="font-semibold text-deep-slate">Connect on LinkedIn</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <div class="w-6 h-10 border-2 border-deep-slate/30 rounded-full flex justify-center">
                <div class="w-1 h-2 bg-vibrant-teal rounded-full mt-2 animate-pulse"></div>
            </div>
        </div>
    </section>

    <!-- Contact Form and Info Section -->
    <section class="py-16 pb-28 bg-white relative">
        <div class="max-w-7xl mx-auto px-6 md:px-10">
            <div class="grid lg:grid-cols-2 gap-12">
                <!-- Contact Form -->
                <div class="reveal-on-scroll">
                    <div class="bg-white rounded-2xl shadow-xl p-8 md:p-10 border border-gray-100">
                        <h2 class="text-2xl font-bold mb-2 text-deep-slate">Send us a message</h2>
                        <p class="text-gray-500 mb-6">Fill out the form and we'll get back to you within 24 hours.</p>

                        <form id="contactForm" method="POST" action="/contact.php">
                            <!-- Honeypot field -->
                            <div style="position: absolute; left: -9999px; top: -9999px;">
                                <label for="website">Website</label>
                                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
                            </div>

                            <div class="mb-5">
                                <label class="block text-gray-700 font-semibold mb-2" for="name">
                                    Full Name <span class="text-red-500">*</span>
                                </label>
                                <input
                                    type="text"
                                    id="name"
                                    name="name"
                                    required
                                    minlength="2"
                                    maxlength="100"
                                    pattern="[a-zA-Z\s\'-]+"
                                    title="Please enter a valid name (letters, spaces, apostrophes, and hyphens only)"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-vibrant-teal focus:ring-2 focus:ring-vibrant-teal/20 transition-all"
                                />
                            </div>

                            <div class="mb-5">
                                <label class="block text-gray-700 font-semibold mb-2" for="email">
                                    Email Address <span class="text-red-500">*</span>
                                </label>
                                <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    maxlength="100"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-vibrant-teal focus:ring-2 focus:ring-vibrant-teal/20 transition-all"
                                />
                            </div>

                            <div class="mb-5">
                                <label class="block text-gray-700 font-semibold mb-2" for="phone">Phone Number</label>
                                <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    pattern="[0-9+\-\s\(\)]+"
                                    title="Please enter a valid phone number"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-vibrant-teal focus:ring-2 focus:ring-vibrant-teal/20 transition-all"
                                />
                            </div>

                            <div class="mb-6">
                                <label class="block text-gray-700 font-semibold mb-2" for="message">
                                    Message <span class="text-red-500">*</span>
                                </label>
                                <textarea
                                    id="message"
                                    name="message"
                                    rows="6"
                                    required
                                    minlength="10"
                                    maxlength="5000"
                                    placeholder="Tell us about your goals, challenges, and where your business is headed..."
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-vibrant-teal focus:ring-2 focus:ring-vibrant-teal/20 transition-all"
                                >
                                </textarea>
                                <div class="text-xs text-gray-500 mt-1">Minimum 10 characters</div>
                            </div>

                            <input type="hidden" name="csrf_token" id="csrf_token" value="" />

                            <button
                                type="submit"
                                class="w-full bg-gradient-to-r from-rich-blue to-vibrant-teal text-white py-4 rounded-lg font-semibold text-lg shadow-md hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300"
                            >
                                Send Message <i class="fas fa-paper-plane ml-2"></i>
                            </button>

                            <div id="formStatus" class="mt-4 text-center hidden"></div>
                        </form>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="reveal-on-scroll" style="transition-delay: 0.2s;">
                    <!-- Process Steps -->
                    <div class="bg-gradient-to-br from-deep-slate to-rich-blue rounded-2xl p-8 md:p-10 text-white mb-8">
                        <h3 class="text-2xl font-bold mb-6">What Happens After You Reach Out:</h3>

                        <div class="space-y-6">
                            <div class="flex gap-4 group">
                                <div
                                    class="flex-shrink-0 w-12 h-12 bg-amber rounded-full flex items-center justify-center text-deep-slate font-bold text-xl group-hover:scale-110 transition-transform"
                                >
                                    01
                                </div>
                                <div>
                                    <h4 class="font-bold text-lg mb-1">Discovery Call</h4>
                                    <p class="text-white/80 text-sm">We'll get to know your goals, challenges, and where your business is headed.</p>
                                </div>
                            </div>

                            <div class="flex gap-4 group">
                                <div
                                    class="flex-shrink-0 w-12 h-12 bg-amber rounded-full flex items-center justify-center text-deep-slate font-bold text-xl group-hover:scale-110 transition-transform"
                                >
                                    02
                                </div>
                                <div>
                                    <h4 class="font-bold text-lg mb-1">Strategy Snapshot</h4>
                                    <p class="text-white/80 text-sm">
                                        Based on your needs, we'll create a high-level snapshot of areas to optimize—whether that's scaling systems,
                                        aligning teams, or prepping for investors.
                                    </p>
                                </div>
                            </div>

                            <div class="flex gap-4 group">
                                <div
                                    class="flex-shrink-0 w-12 h-12 bg-amber rounded-full flex items-center justify-center text-deep-slate font-bold text-xl group-hover:scale-110 transition-transform"
                                >
                                    03
                                </div>
                                <div>
                                    <h4 class="font-bold text-lg mb-1">Engagement Planning</h4>
                                    <p class="text-white/80 text-sm">
                                        If there's a fit, we'll outline a consulting path or fractional engagement built to drive results and support
                                        your leadership team every step of the way.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Contact Info Card -->
                    <div class="bg-white rounded-2xl shadow-lg p-8 border border-gray-100 hover:shadow-xl transition-shadow">
                        <h3 class="text-xl font-bold mb-5 text-deep-slate flex items-center gap-2">
                            <i class="fas fa-user text-vibrant-teal"></i>
                            Bravis Brown
                        </h3>
                        <div class="mb-4 pb-4 border-b border-gray-100">
                            <p class="text-gray-500 text-sm">Principal Consultant</p>
                            <p class="font-semibold text-deep-slate">ElevateEdge Consulting, LLC</p>
                        </div>

                        <div class="space-y-4">
                            <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 transition cursor-pointer group">
                                <div
                                    class="w-10 h-10 bg-vibrant-teal/10 rounded-full flex items-center justify-center group-hover:bg-vibrant-teal/20 transition"
                                >
                                    <i class="fas fa-phone-alt text-vibrant-teal"></i>
                                </div>
                                <div>
                                    <div class="text-sm text-gray-500">Mobile</div>
                                    <div class="font-semibold text-deep-slate">(432) 254-8288</div>
                                </div>
                            </div>

                            <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 transition cursor-pointer group">
                                <div
                                    class="w-10 h-10 bg-vibrant-teal/10 rounded-full flex items-center justify-center group-hover:bg-vibrant-teal/20 transition"
                                >
                                    <i class="fas fa-envelope text-vibrant-teal"></i>
                                </div>
                                <div>
                                    <div class="text-sm text-gray-500">Email</div>
                                    <div class="font-semibold text-deep-slate">Bravis@ElevateEdgeTX.com</div>
                                </div>
                            </div>

                            <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 transition cursor-pointer group">
                                <div
                                    class="w-10 h-10 bg-vibrant-teal/10 rounded-full flex items-center justify-center group-hover:bg-vibrant-teal/20 transition"
                                >
                                    <i class="fab fa-linkedin text-vibrant-teal"></i>
                                </div>
                                <div>
                                    <div class="text-sm text-gray-500">LinkedIn</div>
                                    <div class="font-semibold text-deep-slate">Bravis Brown, MBA</div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <a href="https://ElevateEdgeTX.com" target="_blank" class="text-sm text-vibrant-teal hover:underline">
                                www.ElevateEdgeTX.com
                            </a>
                        </div>
                    </div>

                    <!-- Trust Badge -->
                    <div class="mt-6 text-center">
                        <div class="inline-flex items-center gap-4 text-sm text-gray-400">
                            <span><i class="fas fa-lock"></i> Your info is secure</span>
                            <span><i class="fas fa-reply-all"></i> 24hr response</span>
                            <span><i class="fas fa-calendar-check"></i> Free consultation</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <Footer />

    <script is:inline>
        function generateCSRFToken() {
            return Math.random().toString(36).substring(2) + Date.now().toString(36);
        }

        const csrfTokenInput = document.getElementById('csrf_token');
        if (csrfTokenInput) {
            csrfTokenInput.value = generateCSRFToken();
        }

        const form = document.getElementById('contactForm');
        const statusDiv = document.getElementById('formStatus');

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const name = document.getElementById('name');
                const email = document.getElementById('email');
                const message = document.getElementById('message');

                if (name.value.trim().length < 2) {
                    showStatus('Please enter your full name', 'error');
                    name.focus();
                    return;
                }

                const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailRegex.test(email.value)) {
                    showStatus('Please enter a valid email address', 'error');
                    email.focus();
                    return;
                }

                if (message.value.trim().length < 10) {
                    showStatus('Message must be at least 10 characters', 'error');
                    message.focus();
                    return;
                }

                const submitBtn = form.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = 'Sending... <i class="fas fa-spinner fa-spin ml-2"></i>';
                submitBtn.disabled = true;

                const formData = new FormData(form);

                try {
                    const response = await fetch('/contact.php', {
                        method: 'POST',
                        body: formData,
                    });

                    const result = await response.json();

                    if (result.success) {
                        showStatus(result.message, 'success');
                        form.reset();
                        csrfTokenInput.value = generateCSRFToken();
                    } else {
                        showStatus(result.errors.join(', '), 'error');
                    }
                } catch (error) {
                    console.error('Error:', error);
                    showStatus('Unable to send message. Please try again or call us directly.', 'error');
                } finally {
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            });
        }

        function showStatus(message, type) {
            statusDiv.textContent = message;
            statusDiv.className = `mt-4 text-center p-3 rounded-lg ${type === 'success' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'}`;
            statusDiv.classList.remove('hidden');

            setTimeout(() => {
                statusDiv.classList.add('hidden');
            }, 5000);

            statusDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
    </script>
</Layout>
