---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import TestimonialSlider from '../components/TestimonialSlider.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About Us | ElevateEdge Consulting">
    <!-- Custom cursor -->
    <div class="cursor-dot hidden md:block"></div>

    <Navigation />

    <!-- Hero Section -->
    <section class="relative min-h-[60vh] pt-36 pb-24 md:pt-44 overflow-hidden">
        <!-- Animated gradient orbs -->
        <div class="orb w-[500px] h-[500px] bg-vibrant-teal/30 top-20 -left-48" style="animation-delay: 0s;"></div>
        <div class="orb w-[400px] h-[400px] bg-amber/20 bottom-20 -right-48" style="animation-delay: 2s;"></div>
        <div class="orb w-[300px] h-[300px] bg-rich-blue/20 top-1/2 left-1/2 -translate-x-1/2" style="animation-delay: 4s;"></div>

        <div class="relative max-w-7xl mx-auto px-6 md:px-10">
            <div class="text-center max-w-4xl mx-auto">
                <div class="reveal-on-scroll">
                    <div
                        class="inline-flex items-center gap-2 bg-vibrant-teal/10 backdrop-blur-sm px-4 py-2 rounded-full mb-8 border border-vibrant-teal/20"
                    >
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-vibrant-teal opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-vibrant-teal"></span>
                        </span>
                        <span class="text-xs font-semibold text-vibrant-teal tracking-wide">ABOUT ELEVATEEDGE</span>
                    </div>

                    <h1 class="text-5xl md:text-6xl lg:text-7xl font-black leading-[1.1] tracking-tight mb-6">
                        Growth isn't a
                        <span class="shimmer-text">guessing game</span>
                        <br />—it's a system.
                    </h1>

                    <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-2xl mx-auto">And we build it with you.</p>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <div class="w-6 h-10 border-2 border-deep-slate/30 rounded-full flex justify-center">
                <div class="w-1 h-2 bg-vibrant-teal rounded-full mt-2 animate-pulse"></div>
            </div>
        </div>
    </section>

    <!-- Main Content Section -->
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-6 md:px-10">
            <!-- Company Description -->
            <div class="max-w-4xl mx-auto text-center mb-20 reveal-on-scroll">
                <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
                    At ElevateEdge, we help business owners and leadership teams align strategy, operations, and execution—so growth becomes
                    intentional, not accidental. Whether you're scaling up, preparing for exit, or repositioning after a major shift, we partner with
                    you to create real traction across your team, systems, and goals.
                </p>
            </div>

            <!-- Mission Statement -->
            <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
                <div class="reveal-on-scroll">
                    <h2 class="text-3xl md:text-4xl font-black mb-6 text-deep-slate">
                        We don't believe in <span class="text-rich-blue">surface-level strategy.</span>
                    </h2>
                    <p class="text-gray-600 text-lg leading-relaxed mb-6">
                        We go deep—into your leadership model, operational gaps, and performance blind spots—to design a business that's built to
                        scale. Our goal is to turn your potential into a repeatable, measurable success engine.
                    </p>
                    <div class="flex items-center gap-4 mt-8">
                        <div
                            class="w-16 h-16 bg-gradient-to-br from-rich-blue to-vibrant-teal rounded-full flex items-center justify-center text-white font-bold text-2xl"
                        >
                            B
                        </div>
                        <div>
                            <div class="font-bold text-deep-slate text-lg">Bravis Brown</div>
                            <div class="text-gray-500">Founder</div>
                        </div>
                    </div>
                </div>
                <div class="reveal-on-scroll" style="transition-delay: 0.2s;">
                    <div class="bg-gradient-to-br from-deep-slate/5 to-rich-blue/5 rounded-2xl p-8 border border-gray-100">
                        <div class="text-6xl font-black text-vibrant-teal/20 mb-4">25+</div>
                        <div class="text-2xl font-bold text-deep-slate mb-2">Years of Executive Experience</div>
                        <p class="text-gray-600">
                            Operations, finance, and growth strategy across manufacturing, oil & gas, private equity, and service sectors.
                        </p>
                    </div>
                </div>
            </div>

            <!-- NEW: Founder's Journey / Pivot Proof Section -->
            <div class="mb-24 reveal-on-scroll">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <div class="order-2 lg:order-1">
                        <div class="inline-flex items-center gap-2 bg-vibrant-teal/10 px-4 py-1.5 rounded-full mb-4">
                            <span class="text-xs font-semibold text-vibrant-teal">THE PIVOT PROOF</span>
                        </div>
                        <h2 class="text-3xl md:text-4xl font-black mb-4 text-deep-slate">Why I built this differently</h2>
                        <p class="text-gray-600 text-lg leading-relaxed mb-4">
                            I've sat in your chair. I know what it feels like when every decision routes through you, when growth feels dangerous, and
                            when "delegation" just means you're still answering questions—just from a different person.
                        </p>
                        <p class="text-gray-600 text-lg leading-relaxed mb-4">
                            After scaling a manufacturing company myself, I realized something critical: <span class="font-semibold">
                                Strategy without execution isn't strategy—it's a daydream.
                            </span> And execution without systems, accountability, and visibility is just chaos wearing a busy badge.
                        </p>
                        <p class="text-gray-600 text-lg leading-relaxed">
                            That's why ElevateEdge doesn't hand you a report and walk away. We install the operating systems, cadence, and decision
                            rights that make good execution the default—not the exception.
                        </p>
                        <div class="mt-6 p-4 bg-gradient-to-r from-vibrant-teal/5 to-amber/5 rounded-xl border-l-4 border-vibrant-teal">
                            <p class="text-deep-slate font-medium italic">
                                "I don't help you work harder. I help you remove what's consuming your bandwidth so your business runs without you in
                                the middle of everything."
                            </p>
                            <p class="text-vibrant-teal font-semibold mt-2">— Bravis Brown</p>
                        </div>
                    </div>
                    <div class="order-1 lg:order-2 relative">
                        <div class="absolute -inset-4 bg-gradient-to-r from-vibrant-teal/20 to-amber/20 rounded-3xl blur-2xl"></div>
                        <div class="relative tilt-card">
                            <img
                                src="https://images.pexels.com/photos/3184292/pexels-photo-3184292.jpeg?auto=compress&cs=tinysrgb&w=800&h=600&dpr=2"
                                alt="Bravis Brown - Founder"
                                class="rounded-2xl shadow-2xl w-full object-cover h-[450px] object-center"
                            />
                        </div>
                    </div>
                </div>
            </div>

            <!-- What Sets Us Apart Section -->
            <div class="mb-24">
                <div class="text-center mb-12 reveal-on-scroll">
                    <span class="text-vibrant-teal font-mono text-xs tracking-wider bg-vibrant-teal/10 px-4 py-1.5 rounded-full">
                        WHAT SETS US APART
                    </span>
                    <h2 class="text-3xl md:text-4xl font-black mt-5">Strategy-Focused. <span class="text-rich-blue">Execution-Driven.</span></h2>
                    <p class="text-gray-500 mt-4 max-w-2xl mx-auto">Built for real business.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="gradient-border tilt-card reveal-on-scroll" style="transition-delay: 0.1s;">
                        <div class="bg-white rounded-2xl p-6 h-full hover:shadow-xl transition-all duration-500">
                            <div
                                class="w-14 h-14 bg-gradient-to-br from-vibrant-teal/10 to-vibrant-teal/5 rounded-xl flex items-center justify-center mb-4"
                            >
                                <i class="fas fa-chart-line text-2xl text-vibrant-teal"></i>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-deep-slate">Growth-Ready Consulting</h3>
                            <p class="text-gray-500 text-sm">
                                We help companies implement systems, roles, and strategies that are built to scale—not just survive.
                            </p>
                        </div>
                    </div>

                    <div class="gradient-border tilt-card reveal-on-scroll" style="transition-delay: 0.2s;">
                        <div class="bg-white rounded-2xl p-6 h-full hover:shadow-xl transition-all duration-500">
                            <div
                                class="w-14 h-14 bg-gradient-to-br from-rich-blue/10 to-rich-blue/5 rounded-xl flex items-center justify-center mb-4"
                            >
                                <i class="fas fa-bullseye text-2xl text-rich-blue"></i>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-deep-slate">Strategic Alignment</h3>
                            <p class="text-gray-500 text-sm">
                                Align leadership, operations, and capital with your vision to eliminate friction and unlock performance.
                            </p>
                        </div>
                    </div>

                    <div class="gradient-border tilt-card reveal-on-scroll" style="transition-delay: 0.3s;">
                        <div class="bg-white rounded-2xl p-6 h-full hover:shadow-xl transition-all duration-500">
                            <div class="w-14 h-14 bg-gradient-to-br from-amber/10 to-amber/5 rounded-xl flex items-center justify-center mb-4">
                                <i class="fas fa-handshake text-2xl text-amber"></i>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-deep-slate">High-Touch Partnership</h3>
                            <p class="text-gray-500 text-sm">
                                We work side-by-side with your leadership team—no fluff, no slide decks collecting dust.
                            </p>
                        </div>
                    </div>

                    <div class="gradient-border tilt-card reveal-on-scroll" style="transition-delay: 0.4s;">
                        <div class="bg-white rounded-2xl p-6 h-full hover:shadow-xl transition-all duration-500">
                            <div
                                class="w-14 h-14 bg-gradient-to-br from-muted-teal/10 to-muted-teal/5 rounded-xl flex items-center justify-center mb-4"
                            >
                                <i class="fas fa-chart-pie text-2xl text-muted-teal"></i>
                            </div>
                            <h3 class="text-xl font-bold mb-2 text-deep-slate">Real-World Experience</h3>
                            <p class="text-gray-500 text-sm">With decades in the trenches, we bring operational clarity to complex challenges.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Client Story / Testimonial -->
            <TestimonialSlider />

            <!-- CTA Section -->
            <div class="text-center py-12 reveal-on-scroll">
                <h2 class="text-3xl md:text-4xl font-black mb-4 text-deep-slate">Ready to build what's next?</h2>
                <p class="text-gray-500 text-lg mb-8 max-w-2xl mx-auto">
                    Whether you're restructuring, scaling, or preparing for investment—ElevateEdge helps you lead from the front and build what's
                    next.
                </p>
                <a
                    href="/contact"
                    class="group relative inline-flex items-center gap-3 bg-gradient-to-r from-rich-blue to-vibrant-teal text-white px-8 py-4 rounded-full text-lg font-semibold shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 overflow-hidden"
                >
                    <span class="relative z-10">Start the conversation</span>
                    <i class="fas fa-arrow-right relative z-10 group-hover:translate-x-1 transition"></i>
                    <div
                        class="absolute inset-0 bg-gradient-to-r from-vibrant-teal to-amber opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                    >
                    </div>
                </a>
            </div>
        </div>
    </section>

    <Footer />
</Layout>
